APP_NAME="Factura EC"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=America/Guayaquil

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_EC

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ===========================================
# Database
# ===========================================
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=factura_ec
DB_USERNAME=factura
DB_PASSWORD=secret

# ===========================================
# Cache & Session
# ===========================================
CACHE_DRIVER=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
QUEUE_CONNECTION=redis

# ===========================================
# Redis
# ===========================================
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_CLIENT=predis

# ===========================================
# Storage (MinIO/S3)
# ===========================================
FILESYSTEM_DISK=s3
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=factura-ec
AWS_ENDPOINT=http://minio:9000
AWS_USE_PATH_STYLE_ENDPOINT=true

# ===========================================
# Mail
# ===========================================
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@factura-ec.com"
MAIL_FROM_NAME="${APP_NAME}"

# ===========================================
# Search (Meilisearch)
# ===========================================
SCOUT_DRIVER=meilisearch
MEILISEARCH_HOST=http://meilisearch:7700
MEILISEARCH_KEY=masterKey123

# ===========================================
# Broadcasting (Laravel Reverb)
# ===========================================
BROADCAST_DRIVER=reverb
REVERB_APP_ID=factura-ec
REVERB_APP_KEY=factura-ec-key
REVERB_APP_SECRET=factura-ec-secret
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http

# ===========================================
# SRI Configuration
# ===========================================
SRI_ENVIRONMENT=1
SRI_TIMEOUT=30

# ===========================================
# Payment Gateways
# ===========================================
PAYPHONE_API_URL=https://pay.payphonetodoesposible.com/api
PAYPHONE_TOKEN=
PAYPHONE_STORE_ID=

STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

# ===========================================
# External Services
# ===========================================
OPENAI_API_KEY=

TWILIO_SID=
TWILIO_TOKEN=
TWILIO_WHATSAPP_FROM=

# ===========================================
# Application Settings
# ===========================================
TRIAL_DAYS=14
DEFAULT_PLAN_ID=1
REFERRAL_COMMISSION_PERCENT=20

# ===========================================
# Horizon
# ===========================================
HORIZON_PREFIX=factura-ec-horizon:

# ===========================================
# Filament
# ===========================================
FILAMENT_AUTH_GUARD=web

# ===========================================
# OpenAI (AI Categorization)
# ===========================================
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
