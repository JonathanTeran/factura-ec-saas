# ===========================================
# Factura EC SaaS - Production Environment
# ===========================================
# INSTRUCCIONES:
# 1. Copia este archivo a .env en el servidor de produccion
# 2. Reemplaza TODOS los valores marcados con CAMBIAR_* por valores reales
# 3. Genera APP_KEY con: php artisan key:generate
# 4. NUNCA subas .env a git
# ===========================================

APP_NAME="Factura EC"
APP_ENV=production
APP_KEY=CAMBIAR_GENERAR_CON_ARTISAN_KEY_GENERATE
APP_DEBUG=false
APP_URL=https://CAMBIAR_TU_DOMINIO.com
APP_TIMEZONE=America/Guayaquil

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_EC

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# ===========================================
# Logging
# ===========================================
LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# ===========================================
# Database
# ===========================================
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=factura_ec
DB_USERNAME=factura
DB_PASSWORD=CAMBIAR_PASSWORD_SEGURO_DB
DB_ROOT_PASSWORD=CAMBIAR_PASSWORD_ROOT_DB

# ===========================================
# Cache, Session & Queue (Redis)
# ===========================================
CACHE_STORE=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_DOMAIN=.CAMBIAR_TU_DOMINIO.com
SESSION_SECURE_COOKIE=true
QUEUE_CONNECTION=redis

REDIS_CLIENT=predis
REDIS_HOST=redis
REDIS_PASSWORD=CAMBIAR_PASSWORD_REDIS
REDIS_PORT=6379

# ===========================================
# Storage (S3/MinIO)
# ===========================================
# Opcion A: AWS S3 real
# FILESYSTEM_DISK=s3
# AWS_ACCESS_KEY_ID=CAMBIAR_AWS_KEY
# AWS_SECRET_ACCESS_KEY=CAMBIAR_AWS_SECRET
# AWS_DEFAULT_REGION=us-east-1
# AWS_BUCKET=factura-ec-prod

# Opcion B: MinIO self-hosted (descomenta estas y comenta las de arriba)
FILESYSTEM_DISK=s3
AWS_ACCESS_KEY_ID=CAMBIAR_MINIO_USER
AWS_SECRET_ACCESS_KEY=CAMBIAR_MINIO_PASSWORD
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=factura-ec
AWS_ENDPOINT=http://minio:9000
AWS_USE_PATH_STYLE_ENDPOINT=true

# ===========================================
# Mail (SMTP)
# ===========================================
# Opciones: smtp, ses, mailgun, postmark
MAIL_MAILER=smtp
MAIL_HOST=CAMBIAR_SMTP_HOST
MAIL_PORT=587
MAIL_USERNAME=CAMBIAR_SMTP_USER
MAIL_PASSWORD=CAMBIAR_SMTP_PASSWORD
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@CAMBIAR_TU_DOMINIO.com"
MAIL_FROM_NAME="${APP_NAME}"

# ===========================================
# Search (Meilisearch)
# ===========================================
SCOUT_DRIVER=meilisearch
MEILISEARCH_HOST=http://meilisearch:7700
MEILISEARCH_KEY=CAMBIAR_MEILISEARCH_MASTER_KEY

# ===========================================
# Broadcasting (Laravel Reverb)
# ===========================================
BROADCAST_DRIVER=reverb
REVERB_APP_ID=factura-ec
REVERB_APP_KEY=CAMBIAR_REVERB_KEY
REVERB_APP_SECRET=CAMBIAR_REVERB_SECRET
REVERB_HOST=CAMBIAR_TU_DOMINIO.com
REVERB_PORT=443
REVERB_SCHEME=https

# ===========================================
# Sanctum (API Auth)
# ===========================================
SANCTUM_STATEFUL_DOMAINS=CAMBIAR_TU_DOMINIO.com,www.CAMBIAR_TU_DOMINIO.com

# ===========================================
# SRI Ecuador
# ===========================================
# 1 = pruebas, 2 = produccion
SRI_ENVIRONMENT=2
SRI_TIMEOUT=30

# ===========================================
# WhatsApp (Twilio) - Opcional
# ===========================================
TWILIO_SID=CAMBIAR_SI_USAS_WHATSAPP
TWILIO_TOKEN=CAMBIAR_SI_USAS_WHATSAPP
TWILIO_WHATSAPP_FROM=CAMBIAR_SI_USAS_WHATSAPP

# ===========================================
# AI Categorization (OpenAI) - Opcional
# ===========================================
OPENAI_API_KEY=CAMBIAR_SI_USAS_AI
OPENAI_MODEL=gpt-4o-mini

# ===========================================
# Application Settings
# ===========================================
TRIAL_DAYS=14
DEFAULT_PLAN_ID=1
REFERRAL_COMMISSION_PERCENT=20

# ===========================================
# Horizon (Queue Dashboard)
# ===========================================
HORIZON_PREFIX=factura-ec-horizon:

# ===========================================
# Telescope & Pulse (Monitoring)
# ===========================================
TELESCOPE_ENABLED=false
PULSE_ENABLED=false

# ===========================================
# Filament (Admin Panel)
# ===========================================
FILAMENT_AUTH_GUARD=web

# ===========================================
# Vite
# ===========================================
VITE_APP_NAME="${APP_NAME}"
